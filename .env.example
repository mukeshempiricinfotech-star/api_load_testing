NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/api_load_testing
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-me-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-me-with-a-long-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_CURRENCY=usd

# Datadog (US5 account)
DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_ENV=development
DD_SERVICE=api-load-testing
DD_VERSION=1.0.0
DD_TRACE_ENABLED=false
DD_METRICS_ENABLED=false
DD_AGENT_HOST=127.0.0.1

# Google Analytics 4 Measurement Protocol
# Create these under Admin > Data streams > Web > Measurement Protocol API secrets.
GA_MEASUREMENT_ID=
GA_API_SECRET=
# Aggregate, non-personal client ID used for server-side API monitoring.
GA_CLIENT_ID=api-load-testing.1
